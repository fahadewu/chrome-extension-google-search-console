{
  "manifest_version": 3,
  "name": "Search Console Peek",
  "version": "1.0.0",
  "description": "See your Google Search Console performance — top queries, pages, trends and period comparisons — without leaving your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/app.html",
    "default_title": "Search Console Peek",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/app.html"
  },
  "permissions": ["identity", "storage", "activeTab", "sidePanel"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "REPLACE_WITH_YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/webmasters.readonly"]
  }
}
